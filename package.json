{
    "name": "cherri-v2",
    "version": "2.0.0",
    "type": "module",
    "scripts": {
        "start": "bun src/index.ts",
        "dev": "bun --watch src/dev.ts",
        "normalize:truffled": "bun scripts/normalize-truffled.ts",
        "deploy": "netlify deploy --prod && vercel deploy --prod",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun src/db/migrate.ts",
        "start:prod": "bun run db:migrate && bun run start",
        "lint": "eslint \"public/assets/js/cherri*.js\" \"drizzle.config.js\"",
        "lint:fix": "eslint \"public/assets/js/cherri*.js\" \"drizzle.config.js\" --fix",
        "format": "prettier --write \"src/**/*.ts\" \"public/assets/js/cherri*.js\" \"drizzle.config.js\"",
        "format:check": "prettier --check \"src/**/*.ts\" \"public/assets/js/cherri*.js\" \"drizzle.config.js\"",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@mercuryworkshop/wisp-js": "^0.4.1",
        "drizzle-orm": "^0.45.1",
        "livekit-client": "^2.19.1",
        "livekit-server-sdk": "^2.15.4",
        "sharp": "^0.34.5"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "^1.3.9",
        "drizzle-kit": "^0.31.9",
        "eslint": "^10.0.2",
        "globals": "^17.3.0",
        "prettier": "^3.8.1",
        "strip-comments": "^2.0.1",
        "typescript": "^5.9.3"
    }
}
